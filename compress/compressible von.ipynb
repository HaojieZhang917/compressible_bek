   "source": [
    "function velocity(u)\n",
    "\n",
    "    U = u[1 , :]\n",
    "    dU = u[2 , :]\n",
    "    V = -1 * u[3 , :]\n",
    "    dV = -1 * u[4 , :]\n",
    "    W = u[5 , :]\n",
    "    phi = 0.001 .* cumsum(U)\n",
    "    N = itp = interpolate(t, U , BSplineOrder(4))\n",
    "    N1 = itp = interpolate(t, dU , BSplineOrder(4))\n",
    "    N2 = itp = interpolate(t, dV , BSplineOrder(4))\n",
    "    N3 = itp = interpolate(t, phi , BSplineOrder(4))\n",
    "    \n",
    "    return N,N1,N2,N3,U,V,W,phi\n",
    "\n",
    "end"
   ]
  },
  {
