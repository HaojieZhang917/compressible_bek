   "source": [
    "function caculate_z(t :: StepRangeLen , gamma , Mx , Tw , f , q)\n",
    "    start = t.ref.hi\n",
    "    step = t.step.hi\n",
    "    len = t.len\n",
    "    z = zeros(len , 1)\n",
    "    integ_f = 0\n",
    "    integ_q = 0\n",
    "    for i = 1 : len\n",
    "        z[i,1] = t[i,1] - (gamma - 1) / 2 * Mx^2 * integ_f + (Tw - 1) * integ_q\n",
    "        integ_f = f[i,1] * step + integ_f\n",
    "        integ_q = q[i,1] * step + integ_q\n",
    "    end\n",
    "    return z\n",
    "end"
   ]
  },
