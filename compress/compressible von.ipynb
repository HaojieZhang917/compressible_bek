   "source": [
    "function com_von_T(f ,q ,Mx ,gamma ,Tw)\n",
    "    T = 1 .-(gamma-1)/2 * Mx^2 .* f .+ (Tw - 1) .*q\n",
    "    return T\n",
    "end\n",
    "##\n",
    "function com_von_W(phi,T)\n",
    "    W = -2 * T .* phi\n",
    "end"
   ]
  },
